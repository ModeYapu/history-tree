# AI配置 - 使用DeepSeek（推荐）

# AI提供商
AI_PROVIDER=deepseek

# DeepSeek配置
DEEPSEEK_API_KEY=sk-xxxxx  # 你的DeepSeek API密钥
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 可选模型:
# - deepseek-chat (通用对话，¥1/百万tokens)
# - deepseek-coder (编程专用，¥1/百万tokens)
# - deepseek-reasoner (深度推理R1，¥2/百万tokens)

# 性能配置
CACHE_ENABLED=true
STREAM_ENABLED=true
MAX_CONCURRENT=100
REQUEST_TIMEOUT=30000

# 备用配置（可选）
# FALLBACK_PROVIDER=openai
# OPENAI_API_KEY=sk-xxxxx
